# =============================================================================
# Terraform .gitignore
# Elastic Cloud Terraform Provider — elastic/ec
# =============================================================================


# -----------------------------------------------------------------------------
# Terraform Core
# -----------------------------------------------------------------------------

# Local .terraform directory — downloaded providers & modules
.terraform/
.terraform.lock.hcl

# Terraform plan files — may contain sensitive values in plain text
*.tfplan
*.tfplan.json

# Terraform state files — NEVER commit these
# They contain secrets: passwords, API keys, connection strings
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log


# -----------------------------------------------------------------------------
# Sensitive & Secret Files
# -----------------------------------------------------------------------------

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# Allow example/template tfvars to be committed
!*.tfvars.example
!*.tfvars.template
!example.tfvars
!template.tfvars

# Environment files
.env
.env.*
!.env.example

# Elastic Cloud API keys & credentials
*credentials*
*secrets*
*api_key*
*api-key*


# -----------------------------------------------------------------------------
# Terraform Provider Debug Logs
# -----------------------------------------------------------------------------

# Verbose HTTP request log (enabled via verbose = true in provider block)
request.log

# Terraform debug logs
tf.log
terraform.log
TF_LOG*


# -----------------------------------------------------------------------------
# Override Files
# -----------------------------------------------------------------------------

# Override files are not recommended for teams
# https://developer.hashicorp.com/terraform/language/files/override
override.tf
override.tf.json
*_override.tf
*_override.tf.json


# -----------------------------------------------------------------------------
# Generated & Compiled Files
# -----------------------------------------------------------------------------

# Terragrunt cache
.terragrunt-cache/

# Terraspace
.terraspace-cache/

# CDK for Terraform
cdktf.out/
node_modules/

# Terraform docs
.terraform-docs*


# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------

# VSCode
.vscode/
*.code-workspace

# JetBrains (IntelliJ, GoLand, etc.)
.idea/
*.iml
*.iws

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Cursor
.cursor/


# -----------------------------------------------------------------------------
# OS Generated Files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.nfs*


# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------

# Local CI test artifacts
.github/workflows/*.log

# Atlantis
.atlantis/


# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# Files you SHOULD commit:
#   ✅ *.tf               — all Terraform configuration files
#   ✅ *.tfvars.example   — example variable files (no real values)
#   ✅ .terraform.lock.hcl — provider version lock file (controversial but recommended)
#   ✅ README.md / docs/  — documentation
#   ✅ discover.sh        — utility scripts
#
# Files you should NEVER commit:
#   🚫 .terraform/        — provider binaries (regenerated by terraform init)
#   🚫 *.tfstate          — state files contain secrets in plain text
#   🚫 *.tfvars           — may contain API keys, passwords
#   🚫 request.log        — contains raw HTTP including auth headers
#   🚫 EC_API_KEY         — set via environment variable only
